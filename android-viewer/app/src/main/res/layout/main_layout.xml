<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
	xmlns:android="http://schemas.android.com/apk/res/android"	
	android:layout_width="match_parent"
	android:layout_height="match_parent">
	<com.github.grishberg.viewer.CustomGLSurfaceView
		android:id="@+id/gl_surface_view"
		android:layout_width="match_parent"
		android:layout_height="match_parent" />

	<!-- Toolbar поверх GL-вью -->
	<LinearLayout
		android:id="@+id/toolbar"
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:layout_gravity="top"
		android:background="#CC000000"
		android:gravity="end"
		android:orientation="horizontal"
		android:padding="4dp">

		<Button
			android:id="@+id/menu_button"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:text="≡"
			android:textColor="#FFFFFF"
			android:textSize="20sp"
			android:background="#4488FF"
			android:paddingStart="12dp"
			android:paddingEnd="12dp"
			android:paddingTop="6dp"
			android:paddingBottom="6dp" />
	</LinearLayout>

	<!-- Menu popup -->
	<LinearLayout
		android:id="@+id/menu_popup"
		android:layout_width="wrap_content"
		android:layout_height="wrap_content"
		android:layout_gravity="top|end"
		android:layout_marginTop="48dp"
		android:layout_marginEnd="8dp"
		android:background="#DD000000"
		android:orientation="vertical"
		android:visibility="gone"
		android:padding="4dp">

		<Button
			android:id="@+id/menu_editor"
			android:layout_width="180dp"
			android:layout_height="wrap_content"
			android:text="Редактор"
			android:textColor="#FFFFFF"
			android:background="#00000000"
			android:gravity="start"
			android:padding="12dp"
			android:textSize="16sp" />

		<Button
			android:id="@+id/menu_report"
			android:layout_width="180dp"
			android:layout_height="wrap_content"
			android:text="Отчет"
			android:textColor="#FFFFFF"
			android:background="#00000000"
			android:gravity="start"
			android:padding="12dp"
			android:textSize="16sp" />
	</LinearLayout>


	<com.github.grishberg.viewer.DebugOverlayView
		android:id="@+id/debug_overlay"
		android:layout_width="match_parent"
		android:layout_height="match_parent"
		android:visibility="gone"/>

	<!-- Кастомная вьюшка для логов вместо RecyclerView -->
	<com.github.grishberg.viewer.LogListView
		android:id="@+id/logs_recycler_view"
		android:layout_width="match_parent"
		android:layout_height="250dp"
		android:layout_gravity="top"
		android:background="#80000000"
		android:visibility="gone" />

	<!-- TextView для отладочной информации -->
	<TextView
		android:id="@+id/debug_info_text"
		android:layout_width="match_parent"
		android:layout_height="50dp"
		android:layout_gravity="top"
		android:layout_marginTop="250dp"
		android:background="#80000000"
		android:textColor="#FFFFFF"
		android:textSize="12sp"
		android:padding="8dp"
		android:gravity="center_vertical"
		android:visibility="gone" />

	<!-- Панель управления внизу -->
	<LinearLayout
		android:layout_gravity="bottom"
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:visibility="gone"
		android:orientation="vertical">
		<!-- top panel -->
		<LinearLayout
			android:layout_width="match_parent"
			android:layout_height="wrap_content"

			android:background="#80000000"
			android:gravity="center"
			android:orientation="horizontal"
			android:padding="8dp">

			<CheckBox
				android:id="@+id/wire_mode_checkbox"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:text="@string/wire_mode_checkbox_title"
				android:textColor="#FFFFFF" />

			<Button
				android:id="@+id/toggle_logs_button"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:layout_marginStart="16dp"
				android:background="@drawable/button_background"
				android:text="@string/show_logs"
				android:textColor="#FFFFFF" />

			<Button
				android:id="@+id/clear_logs_button"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:layout_marginStart="8dp"
				android:background="@drawable/button_background"
				android:text="@string/clear_logs"
				android:textColor="#FFFFFF" />

		</LinearLayout>
		<!-- bottom panel -->
		<LinearLayout
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_gravity="bottom"
			android:background="#80000000"
			android:gravity="center"
			android:orientation="horizontal"
			android:padding="8dp">

			<Button
				android:id="@+id/prev_10_debug_button"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:layout_marginStart="8dp"
				android:background="@drawable/button_background"
				android:text="@string/prev_10_debug"
				android:textColor="#FFFFFF" />

			<Button
				android:id="@+id/next_10_debug_button"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:layout_marginStart="8dp"
				android:background="@drawable/button_background"
				android:text="@string/next_10_debug"
				android:textColor="#FFFFFF" />


			<Button
				android:id="@+id/prev_debug_button"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:layout_marginStart="8dp"
				android:background="@drawable/button_background"
				android:text="@string/prev_debug"
				android:textColor="#FFFFFF" />

			<Button
				android:id="@+id/next_debug_button"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:layout_marginStart="8dp"
				android:background="@drawable/button_background"
				android:text="@string/next_debug"
				android:textColor="#FFFFFF" />
		</LinearLayout>


	</LinearLayout>
</FrameLayout>


